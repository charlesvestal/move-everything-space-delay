{
  "id": "tapedelay",
  "name": "TapeDelay",
  "abbrev": "TD",
  "version": "0.4.0",
  "description": "Tape delay with flutter and tone shaping",
  "author": "cyrusasfa (port: charlesvestal)",
  "license": "MIT",
  "dsp": "tapedelay.so",
  "api_version": 2,
  "capabilities": {
    "chainable": true,
    "component_type": "audio_fx",
    "ui_hierarchy": {
      "levels": {
        "root": {
          "name": "TapeDelay",
          "params": [
            {
              "key": "time",
              "label": "Time",
              "type": "int",
              "min": 20,
              "max": 2000,
              "default": 400,
              "step": 1,
              "unit": "ms"
            },
            {
              "key": "division",
              "label": "Division",
              "type": "enum",
              "options": ["free", "1/1", "1/2", "1/2d", "1/4", "1/4d", "1/4t", "1/8", "1/8d", "1/8t", "1/16", "1/16t"],
              "default": 0
            },
            {
              "key": "feedback",
              "label": "Feedback",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.4,
              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "mix",
              "label": "Mix",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.35,
              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "tone",
              "label": "Tone",
              "type": "float",
              "min": 0.0,
              "max": 1.0,
              "default": 0.6,
              "step": 0.01,
              "unit": "%"
            },
            {
              "key": "stereo_width",
              "label": "Stereo Width",
              "type": "int",
              "min": 0,
              "max": 100,
              "default": 0,
              "step": 1,
              "unit": "%"
            }
          ],
          "knobs": [
            "time",
            "division",
            "feedback",
            "mix",
            "tone",
            "stereo_width"
          ]
        }
      }
    }
  }
}
